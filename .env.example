# Database (local Docker Postgres — see docker-compose.yml)
DATABASE_URL="postgresql://nodecode:nodecode_dev@localhost:5432/nodecode?schema=public"

# GitHub OAuth App (create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Session JWT signing secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# AES-256-GCM key for encrypting githubAccessToken at rest — generate same as above
ENCRYPTION_KEY=""

# App base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
